---
import CtaBanner from "../components/sections/CtaBanner.astro";
import FaqAccordion from "../components/sections/FaqAccordion.astro";
import FaqHero from "../components/sections/FaqHero.astro";
import faq from "../content/site/faq.json";
import site from "../content/site/site.json";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="FAQ | Dott.ssa Annachiara Lorusso" description={faq.hero.description}>
  <div class="section-band-muted">
    <FaqHero eyebrow={faq.hero.eyebrow} title={faq.hero.title} description={faq.hero.description} />
  </div>

  <section class="section-pad">
    <div class="container-site">
      <FaqAccordion items={faq.items} />
    </div>
  </section>

  <CtaBanner
    eyebrow="Hai altre domande?"
    title="Contattami per un primo confronto"
    description="Se non trovi qui la risposta che cerchi, scrivimi: risponderò con attenzione al tuo caso specifico."
    primaryLabel="Compila il modulo e scrivimi"
    primaryHref={site.contactFormUrl}
    secondaryLabel="Seguimi su Instagram"
    secondaryHref={site.instagramUrl}
  />
</BaseLayout>
