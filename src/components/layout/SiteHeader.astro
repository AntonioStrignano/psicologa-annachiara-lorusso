---
import navigation from "../../content/site/navigation.json";
import site from "../../content/site/site.json";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="site-header sticky top-0 z-50 border-b border-outline-variant/50 bg-surface/85 backdrop-blur-xl">
  <div class="w-full px-4 py-2 md:px-8 xl:px-12">
    <div class="grid min-h-16 grid-cols-[auto_1fr_auto] items-center gap-3 xl:hidden">
      <a href="/" class="inline-flex items-center">
        <img
          src={site.brandImage}
          alt={`Logo ${site.brandName}`}
          width="46"
          height="46"
          loading="eager"
          decoding="async"
          class="h-10 w-10 rounded-full border border-secondary/25 object-cover"
        />
      </a>

      <a href="/" class="justify-self-center text-center leading-tight">
        <span class="block font-headline text-base text-secondary sm:text-lg">{site.brandName}</span>
        <span class="block text-[0.63rem] font-semibold uppercase tracking-[0.12em] text-on-surface-variant sm:text-[0.68rem]">
          {site.profession}
        </span>
      </a>

      <details class="relative justify-self-end">
        <summary
          class="menu-toggle inline-flex h-10 w-10 list-none items-center justify-center rounded-full border border-outline-variant/80 bg-white/80 text-on-surface-variant"
          aria-label="Apri menu"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </summary>
        <nav
          aria-label="Navigazione mobile"
          class="absolute right-0 top-12 z-50 w-72 rounded-2xl border border-outline-variant/70 bg-white/95 p-3 shadow-lg"
        >
          <ul class="space-y-1">
            {navigation.map((item) => {
              const isActive = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);

              return (
                <li>
                  <a
                    href={item.href}
                    aria-current={isActive ? "page" : undefined}
                    class:list={[
                      "block rounded-xl px-3 py-2 text-sm font-semibold transition-colors",
                      isActive ? "bg-secondary text-white" : "text-on-surface-variant hover:bg-surface-container hover:text-on-surface",
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })}
          </ul>
          <a
            href={`https://wa.me/${site.whatsappNumber}`}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 block rounded-xl border border-outline-variant/80 px-3 py-2 text-sm font-semibold text-on-surface-variant"
          >
            WhatsApp
          </a>
        </nav>
      </details>
    </div>

    <div class="hidden min-h-16 grid-cols-[auto_1fr_auto] items-center gap-4 xl:grid">
      <a href="/" class="group flex items-center gap-3">
        <img
          src={site.brandImage}
          alt={`Logo ${site.brandName}`}
          width="46"
          height="46"
          loading="eager"
          decoding="async"
          class="h-11 w-11 rounded-full border border-secondary/25 object-cover"
        />
        <span class="flex flex-col gap-1">
          <span class="font-headline text-xl leading-tight text-secondary">{site.brandName}</span>
          <span class="text-xs font-semibold uppercase tracking-[0.18em] text-on-surface-variant">
            {site.profession}
          </span>
        </span>
      </a>

      <nav aria-label="Navigazione principale" class="flex items-center gap-1 justify-self-center">
        {navigation.map((item) => {
          const isActive = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);

          return (
            <a
              href={item.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "rounded-full px-4 py-2 text-sm font-semibold transition-colors",
                isActive
                  ? "bg-secondary text-white shadow-[0_10px_25px_rgba(103,88,120,0.24)]"
                  : "text-on-surface-variant hover:bg-white hover:text-on-surface",
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <div class="flex items-center gap-3 justify-self-end">
        <a href={`https://wa.me/${site.whatsappNumber}`} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-on-surface-variant hover:text-secondary">
          WhatsApp
        </a>
      </div>
    </div>
  </div>
</header>