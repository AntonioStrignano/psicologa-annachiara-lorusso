---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && (
    <p class="section-eyebrow mb-3 reveal-fade">
      {eyebrow}
    </p>
  )}
  <h2 class="reveal-fade-delay max-w-2xl font-headline text-3xl leading-tight text-secondary md:text-5xl">
    {title}
  </h2>
  {description && <p class="mt-4 text-lg leading-relaxed text-on-surface-variant md:text-[1.08rem]">{description}</p>}
</div>