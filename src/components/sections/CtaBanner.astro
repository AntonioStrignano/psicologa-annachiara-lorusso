---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  eyebrow,
  title,
  description,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
} = Astro.props;

const shouldOpenInNewTab = (href: string) => /(?:forms\.gle|instagram\.com|wa\.me)/i.test(href);
---

<section class="section-pad">
  <div class="container-site">
    <div class="relative overflow-hidden rounded-[2rem] border border-secondary/22 bg-secondary-container/55 px-8 py-6 text-primary shadow-[0_22px_48px_rgba(103,88,120,0.2)] md:px-10 md:py-8">
      <div class="pointer-events-none absolute -left-14 top-3 h-44 w-44 rounded-full bg-white/35 blur-2xl"></div>
      <div class="pointer-events-none absolute bottom-2 right-8 h-52 w-52 rounded-full bg-primary/16 blur-3xl"></div>
      <div class="relative z-10">
      {eyebrow && <p class="mb-3 text-xs font-bold uppercase tracking-[0.16em] text-primary/75">{eyebrow}</p>}
      <h2 class="font-headline text-3xl text-primary md:text-4xl">{title}</h2>
      <p class="mt-3 max-w-2xl leading-relaxed text-primary/85">{description}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href={primaryHref}
          target={shouldOpenInNewTab(primaryHref) ? "_blank" : undefined}
          rel={shouldOpenInNewTab(primaryHref) ? "noopener noreferrer" : undefined}
          class="rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:brightness-95"
        >
          {primaryLabel}
        </a>
        {secondaryLabel && secondaryHref && (
          <a
            href={secondaryHref}
            target={shouldOpenInNewTab(secondaryHref) ? "_blank" : undefined}
            rel={shouldOpenInNewTab(secondaryHref) ? "noopener noreferrer" : undefined}
            class="rounded-full border border-primary/35 bg-white/70 px-6 py-3 text-sm font-semibold text-primary transition hover:-translate-y-0.5 hover:bg-white"
          >
            {secondaryLabel}
          </a>
        )}
      </div>
      </div>
    </div>
  </div>
</section>