---
import site from "../../content/site/site.json";

interface Cta {
  label: string;
  href: string;
}

interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  focusEyebrow?: string;
  focusTitle?: string;
  focusDescription?: string;
  primaryCta: Cta;
  secondaryCta: Cta;
}

const {
  eyebrow,
  title,
  subtitle,
  focusEyebrow = "Percorsi personalizzati",
  focusTitle = "Uno spazio professionale in cui sentirti accolto.",
  focusDescription = "Interventi clinici orientati alla chiarezza, alla regolazione emotiva e a un cambiamento sostenibile nel quotidiano.",
  primaryCta,
  secondaryCta,
} = Astro.props;

const shouldOpenInNewTab = (href: string) => /(?:forms\.gle|instagram\.com|wa\.me)/i.test(href);
---

<section class="section-pad bg-atmosphere-primary">
  <div class="container-site">
    <div class="grid items-center gap-8 lg:grid-cols-[1.08fr_0.92fr]">
      <div class="card-soft-elevated card-highlight p-8 md:p-12">
        <p class="section-eyebrow mb-3 reveal-fade">{eyebrow}</p>
        <h1 class="reveal-fade-delay max-w-3xl font-headline text-4xl leading-tight text-on-surface md:text-6xl">{title}</h1>
        <p class="mt-4 max-w-3xl text-lg leading-relaxed text-on-surface-variant">{subtitle}</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a
            href={primaryCta.href}
            target={shouldOpenInNewTab(primaryCta.href) ? "_blank" : undefined}
            rel={shouldOpenInNewTab(primaryCta.href) ? "noopener noreferrer" : undefined}
            class="btn-primary-hero"
          >
            {primaryCta.label}
          </a>
          <a
            href={secondaryCta.href}
            target={shouldOpenInNewTab(secondaryCta.href) ? "_blank" : undefined}
            rel={shouldOpenInNewTab(secondaryCta.href) ? "noopener noreferrer" : undefined}
            class="btn-secondary-hero"
          >
            {secondaryCta.label}
          </a>
        </div>
      </div>

      <div class="relative min-h-[260px] overflow-hidden rounded-[2rem] border border-white/60 bg-white/70 p-6 shadow-[0_24px_55px_rgba(89,74,107,0.18)] md:min-h-[300px] md:p-7">
        <div class="absolute -left-12 top-18 h-44 w-44 rounded-full bg-secondary/22 blur-2xl"></div>
        <div class="absolute bottom-4 right-6 h-52 w-52 rounded-full bg-tertiary/20 blur-3xl"></div>
        <div class="relative z-10 mt-8 space-y-3 md:mt-10">
          <div class="mb-5 inline-flex items-center gap-4 rounded-3xl border border-outline-variant/35 bg-white/85 p-4 shadow-[0_14px_30px_rgba(103,88,120,0.18)]">
            <img
              src={site.portraitImage}
              alt={`Ritratto di ${site.brandName}`}
              width="144"
              height="144"
              loading="lazy"
              decoding="async"
              class="h-32 w-32 rounded-2xl border border-secondary/20 object-cover object-top md:h-36 md:w-36"
            />
            <span class="text-sm font-semibold uppercase tracking-[0.12em] text-secondary">Studio professionale</span>
          </div>
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-secondary">{focusEyebrow}</p>
          <p class="font-headline text-3xl leading-snug text-secondary md:text-4xl">{focusTitle}</p>
          <p class="max-w-md leading-relaxed text-on-surface-variant">
            {focusDescription}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>