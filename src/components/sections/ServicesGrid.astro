---
import SectionHeading from "../layout/SectionHeading.astro";
import site from "../../content/site/site.json";

interface Service {
  title: string;
  description: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  services: Service[];
}

const { eyebrow, title, description, services } = Astro.props;
---

<section class="section-pad bg-atmosphere-soft">
  <div class="container-site">
    <SectionHeading eyebrow={eyebrow} title={title} description={description} />
    <div class="cards-equal-layout mt-10 grid gap-5 md:grid-cols-6">
      {services.map((service, index) => (
        <article class:list={[
          "card-uniform interactive-lift rounded-3xl border border-outline-variant/35 p-6",
          index === 0 && "md:col-span-3 lg:col-span-3",
          index === 1 && "md:col-span-3 lg:col-span-3",
          index === 2 && "md:col-span-3 lg:col-span-3",
          index === 3 && "md:col-span-3 lg:col-span-3",
          index === 1 ? "card-highlight" : "card-soft-elevated",
        ]}>
          <h3 class="font-headline text-2xl text-primary">{service.title}</h3>
          <p class="mt-3 leading-relaxed text-on-surface-variant">{service.description}</p>
        </article>
      ))}

      <article class="card-media md:col-span-3 lg:col-span-3">
        <img src={site.brandImage} alt={`Contesto professionale ${site.brandName}`} loading="lazy" decoding="async" />
        <p class="card-media-caption">Colloqui online e continuità</p>
      </article>
    </div>
  </div>
</section>