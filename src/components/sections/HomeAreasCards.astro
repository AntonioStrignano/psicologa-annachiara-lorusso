---
import SectionHeading from "../layout/SectionHeading.astro";
import site from "../../content/site/site.json";

interface AreaItem {
  title: string;
  description: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  items: AreaItem[];
  ctaLabel?: string;
  ctaHref?: string;
}

const { eyebrow, title, description, items, ctaLabel, ctaHref } = Astro.props;
---

<section class="section-pad section-band-cream">
  <div class="container-site">
    <SectionHeading eyebrow={eyebrow} title={title} description={description} />
    <div class="cards-equal-layout mt-10 grid gap-5 md:grid-cols-6">
      {items.map((item, index) => (
        <article
          class:list={[
            "card-soft-elevated card-uniform interactive-lift rounded-3xl border border-outline-variant/35 p-6",
            index === 0 && "md:col-span-4 lg:col-span-3",
            index === 1 && "md:col-span-2 lg:col-span-3",
            index === 2 && "md:col-span-3 lg:col-span-4",
          ]}
        >
          <h3 class="font-headline text-2xl text-secondary">{item.title}</h3>
          <p class="mt-3 leading-relaxed text-on-surface-variant">{item.description}</p>
        </article>
      ))}

      <article class="card-media card-uniform md:col-span-3 lg:col-span-2">
        <img src={site.brandImage} alt={`Studio professionale ${site.brandName}`} loading="lazy" decoding="async" />
        <p class="card-media-caption">Spazio di ascolto e cura</p>
      </article>
    </div>

    {ctaLabel && ctaHref && (
      <div class="mt-10 flex justify-center">
        <a href={ctaHref} class="btn-secondary-hero">
          {ctaLabel}
        </a>
      </div>
    )}
  </div>
</section>