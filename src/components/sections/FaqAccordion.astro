---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="space-y-4">
  {items.map((item) => (
    <details class="card-soft-elevated interactive-lift group border border-outline-variant/45 p-6">
      <summary class="cursor-pointer list-none pr-8 text-lg font-semibold text-secondary">{item.question}</summary>
      <p class="mt-4 leading-relaxed text-on-surface-variant">{item.answer}</p>
    </details>
  ))}
</div>