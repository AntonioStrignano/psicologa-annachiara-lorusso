---
import site from "../../content/site/site.json";

interface Pillar {
  title: string;
  description: string;
}

interface Props {
  items: Pillar[];
}

const { items } = Astro.props;
---

<section class="section-pad">
  <div class="container-site">
    <p class="section-eyebrow mb-3">Pilastri del metodo</p>
    <h2 class="font-headline text-3xl text-secondary md:text-4xl">Come lavoro insieme a te</h2>
    <div class="cards-equal-layout mt-8 grid gap-5 md:grid-cols-6">
      {items.map((item, index) => (
        <article class:list={[
          "card-uniform interactive-lift rounded-3xl border border-outline-variant/35 p-6",
          index === 0 && "md:col-span-3 lg:col-span-4",
          index === 1 && "md:col-span-3 lg:col-span-2",
          index === 2 && "md:col-span-3 lg:col-span-2",
          index === 3 && "md:col-span-3 lg:col-span-2",
          index === 0 ? "card-highlight" : "card-soft-elevated",
        ]}>
          <h3 class="font-headline text-2xl text-secondary">{item.title}</h3>
          <p class="mt-3 leading-relaxed text-on-surface-variant">{item.description}</p>
        </article>
      ))}

      <article class="card-media md:col-span-6 lg:col-span-2">
        <img src={site.brandImage} alt={`Approccio clinico ${site.brandName}`} loading="lazy" decoding="async" />
        <p class="card-media-caption">Relazione umana e metodo</p>
      </article>
    </div>
  </div>
</section>