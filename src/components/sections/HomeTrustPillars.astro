---
import SectionHeading from "../layout/SectionHeading.astro";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  items: string[];
}

const { eyebrow, title, description, items } = Astro.props;
---

<section class="section-pad section-band-lilac-soft">
  <div class="container-site">
    <SectionHeading eyebrow={eyebrow} title={title} description={description} />
    <ul class="mt-8 grid gap-4 md:grid-cols-3">
      {items.map((item, index) => (
        <li class:list={[
          "card-soft-elevated interactive-lift border border-outline-variant/35 p-5 text-on-surface-variant",
          index === 0 && "card-highlight",
        ]}>
          <span class="mb-3 inline-flex h-8 w-8 items-center justify-center rounded-full bg-primary/12 text-sm font-bold text-primary">
            {index + 1}
          </span>
          <p class="leading-relaxed">{item}</p>
        </li>
      ))}
    </ul>
  </div>
</section>